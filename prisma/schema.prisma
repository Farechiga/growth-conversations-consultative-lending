// Sprint 4 §4.2a Block B — provenance enum for SizingMeasurement.source.
// Distinguishes how the value was sourced: directly from the Member's
// statement, from the Member's own records (e.g., bank statements,
// QuickBooks export), calculated by the banker from observable data,
// or pulled from a market reference (e.g., industry benchmark). The
// distinction matters for Insight Engine analytics (Sprint 5) — banker-
// calculated values get different aggregation treatment than member-
// stated ones.
enum MeasurementSource {
  member_stated
  member_records
  banker_calculated
  market_reference
}

enum BankerStatus {
  active
  inactive
}

enum RecommendationStructure {
  standard
  phased
  conservative_first
  paired_with
}

// RecommendationResponse — extended per Sprint 1 review fix #4.
//
// The schema collapse merged ArtifactShareRecord.member_reaction into this
// enum, on the principle that the last interaction is the truest signal of
// member state and intermediate captures of how the member reacted to
// specific Artifacts during the conversation are subsumed by the final
// Resolve-step response on the Recommendation. Values are ordered
// weakest-negative → strongest-positive so analytical views can sort by
// engagement direction.
//
// `accepted` (prior) renamed to `committed` to align with the Resolve-step
// resolution_type vocabulary; `deferred` (prior) removed — a deferring
// member is now classified by the underlying reason (`neutral`, `confused`,
// `skeptical`).
//
// Value descriptions live in lib/enum-descriptions.ts under
// RECOMMENDATION_RESPONSE_DESCRIPTIONS — required reading for any UI label
// or summary template that surfaces this field.
enum RecommendationResponse {
  declined
  leaning_no
  dismissive
  skeptical
  confused
  neutral
  engaged
  leaning_yes
  committed
  funded
}

// RecommendationStatus enum was retired in Sprint 2 §A.2. Journey state lives
// in `response` alone going forward — the last interaction is the truest
// signal, and a separate status dimension created two ways to ask "where is
// this opportunity" without consistent agreement. Edge cases:
//   - "Paused" opportunities → handled by aging heuristics in priority logic
//   - "Lost" opportunities → transition `response` back to `declined`; the
//     prior `committed` state remains in the audit trail per the existing
//     immutability discipline.

// Recommendation.primary_concern — Sprint 4.6 Block A (compliance posture
// floor) refactored the enum to a strict business-factor-only taxonomy
// per COMPLIANCE.md §6 and the resolved Q-041. The enum now carries two
// context-specific value sets; the resolve form picks the appropriate
// set based on `member_response` and renders the appropriate field
// label:
//
//   Open-thread context (engaged / leaning_yes / committed) — 8 values
//     reflecting business-decision-process facts. Field label:
//     "Primary concern".
//       pricing_concern, terms_concern, timing_concern,
//       co_decision_maker_household, external_advisor, co_owner_or_board,
//       service_or_capability_concern, other_open_thread
//
//   Decline-reason context (declined / dismissive) — 10 values
//     reflecting member-stated business reasons for declining. Field
//     label: "Member's stated reason for declining".
//       pricing_uncompetitive, terms_uncompetitive, timing_misaligned,
//       chose_alternative_lender, chose_alternative_funding,
//       need_resolved_otherwise, need_no_longer_present,
//       wants_to_revisit_later, service_or_capability_concern,
//       other_member_stated
//
// `service_or_capability_concern` appears in both sets with the same
// semantic meaning. All values are member-direction; bank-side
// underwriting determinations (does_not_qualify, etc.) are explicitly
// excluded — those go to Closing notes free text per §8.2 and are
// deferred to Q-042 governance for any future structured capture.
//
// Migration history: prior values (rate / timing / spouse / cpa / partner
// / bank_capability / does_not_qualify / Sprint-4-§4.2a decline values)
// were mapped to the new taxonomy in migration
// `20260429210607_sprint4_6_compliance_taxonomy_refactor`. SQLite stores
// the column as TEXT so DDL is unchanged; the Prisma client validates
// writes against this enum.
enum RecommendationPrimaryConcern {
  // Open-thread context
  pricing_concern
  terms_concern
  timing_concern
  co_decision_maker_household
  external_advisor
  co_owner_or_board
  other_open_thread
  // Decline-reason context
  pricing_uncompetitive
  terms_uncompetitive
  timing_misaligned
  chose_alternative_lender
  chose_alternative_funding
  need_resolved_otherwise
  need_no_longer_present
  wants_to_revisit_later
  other_member_stated
  // Shared across both contexts
  service_or_capability_concern
}

// ============================================================
// Reference data
// ============================================================

// Banker — first-class entity per Data Framework §5.5.
// roles is multi-valued; SQLite has no native arrays so we use Json.
model Banker {
  id               String       @id @default(uuid())
  external_user_id String       @unique
  display_name     String
  roles            Json
  status           BankerStatus @default(active)
  created_at       DateTime     @default(now())

  // Reverse relations
  primary_for_members         Member[]              @relation("MemberPrimaryBanker")
  conversations_led           Conversation[]
  action_cards_owned          ActionCard[]
  // Sprint 2 Prompt 2 §C — Recommendation ownership reverse relation.
  recommendations_owned       Recommendation[]      @relation("RecommendationOwnedBy")
  // Sprint 4 §A.6 — ArtifactParameterCapture authorship reverse relation.
  parameter_captures          ArtifactParameterCapture[]
  // Sprint 4 §A.5 — Macro authorship reverse relation (when authored
  // internally by a Banker; external authors use authored_by_external_label).
  authored_macros             Macro[]
  // Sprint 4 §A.8 — Skip-confirmation reverse relation.
  skip_confirmations          GrowthStepExecution[] @relation("SkipConfirmation")
  authored_growth_steps       GrowthStep[]          @relation("GrowthStepAuthor")
  promoted_growth_steps       GrowthStep[]          @relation("GrowthStepPromoter")
  authored_growth_tracks      GrowthTrack[]         @relation("GrowthTrackAuthor")
  promoted_growth_tracks      GrowthTrack[]         @relation("GrowthTrackPromoter")
  reviewed_artifacts          Artifact[]
  promoted_rules              Rule[]
  authored_private_notes      Json?
  // Sprint 4.6 Block C — compliance scan telemetry reverse relation.
  compliance_scan_events      ComplianceScanEvent[]
  // Sprint 4.7 Block B — v2 phase 1 entities reverse relations.
  built_models                Model[]
  captured_reactions          Reaction[]
  shown_events                ShowEvent[]
}

// IndustryFamily — Data Framework §5.2. Banker-facing label is "Business type".
model IndustryFamily {
  id                    String       @id @default(uuid())
  name                  String       @unique
  description           String
  naics_codes           Json
  size_band_thresholds  Json
  created_at            DateTime     @default(now())

  member_types          MemberType[]
  members               Member[]
}

// Topic — controlled vocabulary for canonical_tag values used by Signal records.
// Banker-facing label is "Topic"; internal field name is canonical_tag.
model Topic {
  id              String       @id @default(uuid())
  canonical_tag   String       @unique
  display_name    String
  description     String
  topic_type      SignalType
  parent_topic_id String?
  parent_topic    Topic?       @relation("TopicHierarchy", fields: [parent_topic_id], references: [id])
  child_topics    Topic[]      @relation("TopicHierarchy")
  status          TopicStatus  @default(canonical)
  created_at      DateTime     @default(now())

  signals                          Signal[]
  member_type_blocker_relations    MemberType[] @relation("MemberTypeBlockers")
  member_type_trigger_relations    MemberType[] @relation("MemberTypeTriggers")
  member_type_goal_relations       MemberType[] @relation("MemberTypeGoals")
  growth_step_trigger_signals      GrowthStep[] @relation("GrowthStepTriggerSignals")
  growth_track_blocker_topics      GrowthTrack[] @relation("GrowthTrackBlockerTopics")
  growth_track_trigger_topics      GrowthTrack[] @relation("GrowthTrackTriggerTopics")

  @@index([canonical_tag])
  @@index([topic_type])
}

// Sprint 4 §4.2a Block B — SizingDimension reference table. Controlled
// vocabulary for what a SizingMeasurement quantifies. Parallel in shape
// to Topic (used by Signal) — banker-facing labels + identifier-safe
// keys + Semantic-Discipline-required descriptions. Demo seeds ~12
// dimensions covering the three featured Members; Pilot phase will
// expand without schema change.
model SizingDimension {
  id           String              @id @default(uuid())
  key          String              @unique
  display_name String
  description  String
  created_at   DateTime            @default(now())

  measurements SizingMeasurement[]

  @@index([key])
}

// Product — Data Framework §5.3.
model Product {
  id                  String              @id @default(uuid())
  name                String              @unique
  description         String
  category            ProductCategory
  subcategory         ProductSubcategory
  routing_owner_role  RoutingOwnerRole
  compliance_tags     Json
  status              ProductStatus       @default(active)
  created_at          DateTime            @default(now())

  funded_action_cards         ActionCard[]
  recommendations             Recommendation[]
  paired_recommendations      Recommendation[] @relation("PairedProduct")
  member_types_typical_for    MemberType[]     @relation("MemberTypeTypicalProducts")
  // Self-relation (complementary products) skipped for demo simplicity; restore via Json on the Product if needed.
}

// Rule — Data Framework §5.4. Surfaces Growth tracks via inspectable conditions.
model Rule {
  id                 String          @id @default(uuid())
  name               String
  description        String
  conditions         Json
  output_growth_tracks GrowthTrack[] @relation("RuleOutputGrowthTracks")
  confidence_band    ConfidenceBand
  compliance_gates   Json
  status             CanonicalStatus @default(canonical)
  version            Int             @default(1)
  promoted_at        DateTime?
  promoted_by_id     String?
  promoted_by        Banker?         @relation(fields: [promoted_by_id], references: [id])
  created_at         DateTime        @default(now())

  recommendations    Recommendation[]
}

// MemberType — Data Framework §3.8. The aggregation frame for the Insight Engine.
model MemberType {
  id                       String         @id @default(uuid())
  name                     String         @unique
  description              String
  industry_family_id       String
  industry_family          IndustryFamily @relation(fields: [industry_family_id], references: [id])
  stage                    Stage
  size_band                SizeBand
  characteristic_blockers  Topic[]        @relation("MemberTypeBlockers")
  characteristic_triggers  Topic[]        @relation("MemberTypeTriggers")
  characteristic_goals     Topic[]        @relation("MemberTypeGoals")
  typical_products         Product[]      @relation("MemberTypeTypicalProducts")
  typical_sequences        Json?
  default_growth_tracks    GrowthTrack[]  @relation("MemberTypeDefaultGrowthTracks")
  segment_notes            String?
  created_at               DateTime       @default(now())

  members                  Member[]
  applicable_growth_tracks GrowthTrack[]  @relation("GrowthTrackTargetMemberType")
  applicable_growth_steps  GrowthStep[]   @relation("GrowthStepTargetMemberTypes")

  @@index([industry_family_id, stage, size_band])
}

// GrowthTrack — Data Framework §3.7.
model GrowthTrack {
  id                       String          @id @default(uuid())
  name                     String          @unique
  description              String
  // Member-specific framing of the Track's purpose, written for the banker
  // reading a Member profile. Distinct from `description` (editor-facing,
  // canonical for the Growth lead's track-editor view) and from
  // ActionCard.suggested_opening (member-facing prose for outbound). Surfaces
  // on the Suggested Next Step card. Per Sprint 1 Prompt 1 §A.3.
  banker_facing_purpose    String?
  target_member_type_id    String
  target_member_type       MemberType      @relation("GrowthTrackTargetMemberType", fields: [target_member_type_id], references: [id])
  target_blocker_topics    Topic[]         @relation("GrowthTrackBlockerTopics")
  target_trigger_topics    Topic[]         @relation("GrowthTrackTriggerTopics")
  growth_step_sequence     GrowthTrackStep[]
  author_id                String
  author                   Banker          @relation("GrowthTrackAuthor", fields: [author_id], references: [id])
  status                   CanonicalStatus @default(canonical)
  promoted_at              DateTime?
  promoted_by_id           String?
  promoted_by              Banker?         @relation("GrowthTrackPromoter", fields: [promoted_by_id], references: [id])
  performance_counts       Json?
  review_due               DateTime?
  created_at               DateTime        @default(now())

  default_for_member_types MemberType[]    @relation("MemberTypeDefaultGrowthTracks")
  surfacing_rules          Rule[]          @relation("RuleOutputGrowthTracks")
}

// GrowthTrackStep — explicit join model for GrowthTrack ↔ GrowthStep so the order
// of Growth steps in a Growth track is preserved (per Data Framework §3.7).
model GrowthTrackStep {
  id                String      @id @default(uuid())
  growth_track_id   String
  growth_track      GrowthTrack @relation(fields: [growth_track_id], references: [id], onDelete: Cascade)
  growth_step_id    String
  growth_step       GrowthStep  @relation(fields: [growth_step_id], references: [id])
  position          Int

  @@unique([growth_track_id, position])
  @@index([growth_track_id])
}

// GrowthStep — Data Framework §3.5.
model GrowthStep {
  id                  String           @id @default(uuid())
  title               String
  description         String
  step_shape          StepShape
  content             String
  variant_phrasings   Json?
  capture_schema      Json
  artifact_id         String?
  artifact            Artifact?        @relation(fields: [artifact_id], references: [id])
  target_member_types MemberType[]     @relation("GrowthStepTargetMemberTypes")
  trigger_signals     Topic[]          @relation("GrowthStepTriggerSignals")
  author_id           String
  author              Banker           @relation("GrowthStepAuthor", fields: [author_id], references: [id])
  status              CanonicalStatus  @default(canonical)
  promoted_at         DateTime?
  promoted_by_id      String?
  promoted_by         Banker?          @relation("GrowthStepPromoter", fields: [promoted_by_id], references: [id])
  performance_counts  Json?
  review_due          DateTime?
  created_at          DateTime         @default(now())

  growth_track_steps  GrowthTrackStep[]
  executions          GrowthStepExecution[]
}

// Artifact — Data Framework §3.6. Compliance-reviewed visual asset.
model Artifact {
  id                  String           @id @default(uuid())
  title               String
  description         String
  type                ArtifactType
  parameter_schema    Json
  template            String
  compliance_status   ComplianceStatus @default(draft)
  last_reviewed_at    DateTime?
  reviewed_by_id      String?
  reviewed_by         Banker?          @relation(fields: [reviewed_by_id], references: [id])
  shareable           Boolean          @default(false)
  use_counts          Json?
  created_at          DateTime         @default(now())

  growth_steps        GrowthStep[]
  // Sprint 4.7 Block B — v2 entities. ShowEvent records when an
  // Artifact is rendered to a Member; Model optionally records that an
  // Artifact was produced by a banker-built model.
  show_events         ShowEvent[]
  models              Model[]
}

// ============================================================
// Member-cluster (transactional)
// ============================================================

model Member {
  id                      String          @id @default(uuid())
  // Sprint 3 §B — stable, URL-safe identifier for the dynamic
  // /members/[id] route. Lowercase, hyphenated; populated explicitly in
  // the seed. Unique across Members. Used in place of the UUID `id`
  // because the UUIDs regenerate on re-seed, making URLs un-bookmarkable
  // for the demo.
  slug                    String          @unique
  legal_name              String
  doing_business_as       String?
  industry_family_id      String
  industry_family         IndustryFamily  @relation(fields: [industry_family_id], references: [id])
  stage                   Stage
  size_band               SizeBand
  // [derived] Computed from industry_family × stage × size_band; set explicitly in the seed.
  member_type_id          String
  member_type             MemberType      @relation(fields: [member_type_id], references: [id])
  primary_banker_id       String
  primary_banker          Banker          @relation("MemberPrimaryBanker", fields: [primary_banker_id], references: [id])
  tenure_started_at       DateTime
  consent_state           Json
  core_sync_state         Json
  private_notes           Json?
  // [derived] Most recent Conversation timestamp; set during seed step 6.
  last_touch_at           DateTime?
  // Sprint 4.7 Block D — v2 key facts strip. 3-5 hand-curated facts
  // per Member fixture for the v2 workstation's key facts strip
  // (ARCHITECTURE_V2 §6.2). Schema:
  //   [{ label: string, value: string, source_type: string,
  //      source_id: string | null }, ...]
  // For demo, hand-curated in seed.ts. For Pilot, an algorithm chooses
  // most-consequential facts from captured evidence; out of demo scope.
  key_facts               Json?
  // Sprint 4.7 Block M — Tracks-supported-by-current-evidence cohort.
  // Hand-curated per fixture per ARCHITECTURE_V2 §10.4 (true cross-
  // portfolio anonymized intelligence is not feasible at three Members).
  // Schema:
  //   {
  //     strong:       [{ track_name, evidence_count, rationale }, ...],
  //     moderate:     [{ track_name, evidence_count, rationale }, ...],
  //     insufficient: [{ track_name, rationale }, ...]
  //   }
  // Surfaced inside the Land objective panel. Compliance-careful framing
  // verbatim per COMPLIANCE.md §10.2 / ARCHITECTURE_V2 §10.2 — never
  // "candidate tracks" or "recommended for".
  tracks_by_evidence_strength Json?
  // Sprint 8 Block A — multi-Track cultivation (fixtures only). JSON
  // array of TrackTemplate.id strings (e.g., ["TRACK-001","TRACK-010"]).
  // First entry is the primary Track (used for ranking displays).
  // Synthetic Members leave this null and fall through to single-Track
  // behavior via the ranked-Track inference. Per CLAUDE.md §2 SQLite
  // demo constraint, we store as Json rather than a join table.
  active_track_ids        Json?
  // [derived] Count of Signals where active = true; set during seed step 6.
  active_signal_count     Int             @default(0)
  // [derived] Count of ActionCards where status in (open, in_progress); set during seed step 6.
  open_action_card_count  Int             @default(0)
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt

  conversations           Conversation[]
  signals                 Signal[]
  action_cards            ActionCard[]
  recommendations         Recommendation[]
  summary_snapshots       MemberSummarySnapshot[]
  sizing_measurements     SizingMeasurement[]
  compliance_scan_events  ComplianceScanEvent[]
  // Sprint 4.7 Block B — v2 entities reverse relations.
  models                  Model[]
  reactions               Reaction[]
  show_events             ShowEvent[]
  // Sprint 5a.1 — Business Factor Matrix reverse relation.
  factor_captures         FactorCapture[]
  // Sprint 5b.1 — Insight architecture + specialist handoff.
  insights                Insight[]
  specialist_handoffs     SpecialistHandoff[]
  // Sprint 5b.2 — denormalized workflow state for portfolio queries.
  workflow_state          MemberWorkflowState?

  @@index([primary_banker_id])
  @@index([member_type_id])
  @@index([industry_family_id, stage, size_band])
}

model Conversation {
  id                      String                 @id @default(uuid())
  member_id               String
  member                  Member                 @relation(fields: [member_id], references: [id])
  banker_id               String
  banker                  Banker                 @relation(fields: [banker_id], references: [id])
  meeting_type            MeetingType
  channel                 Channel
  sentiment               Sentiment
  duration_min            Int?
  moment_quote            String?
  banker_note             String?
  created_at              DateTime               @default(now())
  closed_at               DateTime               @default(now())

  growth_step_executions  GrowthStepExecution[]
  signals                 Signal[]
  origin_action_cards     ActionCard[]
  summary_snapshots       MemberSummarySnapshot[]
  sizing_measurements     SizingMeasurement[]
  // Sprint 4.7 Block B — v2 entities reverse relations.
  models                  Model[]
  reactions               Reaction[]
  show_events             ShowEvent[]

  @@index([member_id])
  @@index([banker_id])
  @@index([created_at])
}

// GrowthStepExecution — Data Framework §3.5 (sub-entity of Conversation).
model GrowthStepExecution {
  id                          String              @id @default(uuid())
  conversation_id             String
  conversation                Conversation        @relation(fields: [conversation_id], references: [id])
  // Sprint 4 §4.1c §C.3 — Approach 2: track-agnostic Ask + Size phases
  // do not link to a specific GrowthStep (those exist only for Show /
  // Resolve / Connect — the post-discovery, track-specific stages).
  // growth_step_id is nullable for track-agnostic captures; step_phase
  // carries the phase identity in those cases. For track-specific
  // executions, both fields populate.
  growth_step_id              String?
  growth_step                 GrowthStep?         @relation(fields: [growth_step_id], references: [id])
  step_phase                  StepShape?
  sequence_position           Int
  captured_data               Json
  executed_at                 DateTime            @default(now())

  // Sprint 4 §A.8 — skip-state tracking for Sprint 4 Prompt 4.3's skip-
  // handling UI. When a banker submits a later stage with this stage
  // unfilled, the popup confirmation creates an execution row with
  // was_skipped=true rather than a fully-captured execution. Insight
  // Engine analytics over skip patterns depends on this shape.
  was_skipped                 Boolean             @default(false)
  skip_confirmed_by_banker_id String?
  skip_confirmed_by_banker    Banker?             @relation("SkipConfirmation", fields: [skip_confirmed_by_banker_id], references: [id])
  skip_confirmed_at           DateTime?
  skip_reason                 String?

  produced_signals            Signal[]
  produced_action_cards       ActionCard[]
  produced_recommendation     Recommendation?
  produced_sizing_measurements SizingMeasurement[]
  // Sprint 4 §A.6 — ArtifactParameterCapture reverse relation. Per the
  // schema comment on ArtifactParameterCapture, the demo's Show-step
  // share-record data lives in this execution's captured_data jsonb;
  // structured parameter rows link here directly. If a future sprint
  // promotes ArtifactShareRecord to a first-class table, the relation
  // can be re-pointed.
  artifact_parameter_captures ArtifactParameterCapture[]

  @@unique([conversation_id, sequence_position])
  @@index([conversation_id])
}

model Signal {
  id                          String                @id @default(uuid())
  conversation_id             String
  conversation                Conversation          @relation(fields: [conversation_id], references: [id])
  growth_step_execution_id    String?
  growth_step_execution       GrowthStepExecution?  @relation(fields: [growth_step_execution_id], references: [id])
  member_id                   String
  member                      Member                @relation(fields: [member_id], references: [id])
  type                        SignalType
  topic_id                    String
  topic                       Topic                 @relation(fields: [topic_id], references: [id])
  // Sprint 4 §4.1d Block C — severity and recency are nullable to support
  // per-type required-field discipline. Indecision Signals make both
  // optional; Trigger Signals replace recency with time_horizon. Goal
  // and Blocker Signals continue to require both, enforced at the
  // application layer (saveAskCaptures + AskSection client validation).
  severity                    Severity?
  their_words                 String?
  recency                     Recency?
  confidence                  SignalConfidence
  active                      Boolean               @default(true)
  // Sprint 4 §4.1d Block C — forward-looking time horizon for Trigger
  // Signals. Goal / Blocker / Indecision Signals continue to use
  // `recency` (recent / ongoing / chronic / hypothetical_future); Trigger
  // Signals use `time_horizon` instead. Both fields are nullable so the
  // capture form can enforce per-type required-field rules at the
  // application layer rather than the schema layer (per the prompt's
  // "validation is per-type" decision in §C.4).
  time_horizon                TimeHorizon?
  // Optional Size-shape quantification carried inline for query convenience.
  // Originally captured inside the Size step's captured_data jsonb; mirrored here so
  // dashboards can query Signal magnitude without unpacking the execution record.
  magnitude                   Float?
  unit                        String?
  frequency                   String?
  feeling                     String?
  captured_at                 DateTime              @default(now())

  // Recommendations that respond to this Signal (Q-016). Reverse side of
  // Recommendation.responds_to_signals; populated for the three featured
  // Recommendations in the seed.
  responding_recommendations  Recommendation[]      @relation("RecommendationRespondsToSignal")

  // Sprint 4 §A.7 — Signal supersession for longevity tracking. When a
  // banker re-enters Growth Conversations months later and updates a
  // stale Signal, the new Signal record references the prior via
  // superseded_by_signal_id and the prior is retained with its original
  // timestamp. Audit trail preserved; current state is "active Signals
  // not yet superseded." No supersessions in current seed (each demo
  // Member has exactly one set of signals from their featured
  // Conversation); Sprint 4 Prompt 4.2 will exercise this when the
  // capture forms allow updating stale Signals.
  superseded_by_signal_id     String?
  superseded_by_signal        Signal?               @relation("SignalSupersession", fields: [superseded_by_signal_id], references: [id])
  superseded_at               DateTime?
  superseding_signals         Signal[]              @relation("SignalSupersession")

  @@index([member_id, active])
  @@index([conversation_id])
  @@index([topic_id])
  @@index([type])
}

// Sprint 4 §4.2a Block B — SizingMeasurement is the unit of capture for
// the Size phase of a Growth Conversation. Tracks-agnostic by design
// (growth_step_execution_id is nullable; the matching execution row
// uses step_phase = "size" with growth_step_id = null per the §4.1c
// architectural decision).
//
// Mirrors Signal's supersession discipline: when a banker re-enters a
// Growth Conversation and updates a measurement (e.g., "the slow-season
// gap is now $52K, not $48K"), the prior row is retained immutably and
// the new row references it via superseded_by_id. Active state is
// "rows where active = true and superseded_by_id is null."
//
// Confidence is stored as String (not enum) for flexibility — the demo's
// dropdown options are { high | moderate | low | banker_estimate }, but
// pilot phase may extend without a migration. Q-036 in OPEN_QUESTIONS
// tracks "should Confidence become required?"; left optional for now.
model SizingMeasurement {
  id                          String                  @id @default(uuid())
  member_id                   String
  member                      Member                  @relation(fields: [member_id], references: [id])
  conversation_id             String
  conversation                Conversation            @relation(fields: [conversation_id], references: [id])
  growth_step_execution_id    String?
  growth_step_execution       GrowthStepExecution?    @relation(fields: [growth_step_execution_id], references: [id])
  dimension_id                String
  dimension                   SizingDimension         @relation(fields: [dimension_id], references: [id])
  magnitude                   Float
  unit                        String
  frequency                   String?
  source                      MeasurementSource
  their_words                 String?
  confidence                  String?
  time_period                 String?
  methodology_note            String?
  active                      Boolean                 @default(true)
  superseded_by_id            String?
  superseded_by               SizingMeasurement?      @relation("SizingMeasurementSupersession", fields: [superseded_by_id], references: [id])
  superseded_at               DateTime?
  superseding_measurements    SizingMeasurement[]     @relation("SizingMeasurementSupersession")
  captured_at                 DateTime                @default(now())

  @@index([member_id, active])
  @@index([conversation_id])
  @@index([dimension_id])
}

model ActionCard {
  id                              String                @id @default(uuid())
  type                            ActionCardType
  owner_id                        String
  owner                           Banker                @relation(fields: [owner_id], references: [id])
  member_id                       String
  member                          Member                @relation(fields: [member_id], references: [id])
  origin_conversation_id          String
  origin_conversation             Conversation          @relation(fields: [origin_conversation_id], references: [id])
  origin_growth_step_execution_id String?
  origin_growth_step_execution    GrowthStepExecution?  @relation(fields: [origin_growth_step_execution_id], references: [id])
  rationale                       String
  suggested_opening               String?
  due_at                          DateTime
  status                          ActionCardStatus      @default(open)
  status_changed_at               DateTime              @default(now())
  outcome                         ActionCardOutcome?
  // outcome_reason kept as String rather than enum so the seed can carry the verbatim
  // brief value; the Data Framework's enum list is enforced at the application layer.
  outcome_reason                  String?
  funded_product_id               String?
  funded_product                  Product?              @relation(fields: [funded_product_id], references: [id])
  created_at                      DateTime              @default(now())
  closed_at                       DateTime?

  @@index([owner_id, status])
  @@index([member_id, status])
  @@index([due_at])
}

// Recommendation — Data Framework §6.1. Modeled as a first-class entity (rather than
// a jsonb blob on Member) so the demo can render it on the Member profile and link it
// back to the originating Growth step execution and Rule.
model Recommendation {
  id                          String                  @id @default(uuid())
  member_id                   String
  member                      Member                  @relation(fields: [member_id], references: [id])
  growth_step_execution_id    String                  @unique
  growth_step_execution       GrowthStepExecution     @relation(fields: [growth_step_execution_id], references: [id])
  product_id                  String
  product                     Product                 @relation(fields: [product_id], references: [id])
  size_proposed               Float?
  structure                   RecommendationStructure
  paired_product_id           String?
  paired_product              Product?                @relation("PairedProduct", fields: [paired_product_id], references: [id])
  rationale_text              String
  confidence_band             ConfidenceBand
  response                    RecommendationResponse
  // primary_concern uses RecommendationPrimaryConcern enum, extended via Q-013
  // (Resolved) with bank_capability. Value descriptions live in
  // app/lib/enum-descriptions.ts so summary templates and UI labels render prose,
  // not bare tokens.
  primary_concern             RecommendationPrimaryConcern?
  // status field retired in Sprint 2 §A.2 — see comment on the now-deleted
  // RecommendationStatus enum. Lifecycle position is read from `response`
  // (committed/funded indicate later-stage; declined indicates terminal-no).
  rule_id_that_fired          String?
  rule_that_fired             Rule?                   @relation(fields: [rule_id_that_fired], references: [id])
  // Sprint 2 Prompt 2 §C — opportunity ownership. Distinct from
  // Member.primary_banker (the relationship banker); ownership routes a
  // specific opportunity to a specialist when the product type warrants
  // it. The demo's example: Cygnus's CRE opportunity is owned by Marcus
  // Webb (CRE specialist) even though Scott Brynjolffson remains the
  // primary banker. Nullable for back-compat with existing rows; the
  // application sets this to Member.primary_banker when not specified.
  owned_by_id                 String?
  owned_by                    Banker?                 @relation("RecommendationOwnedBy", fields: [owned_by_id], references: [id])
  their_words                 String?
  // One-line summary for progressive disclosure on the Member profile (Q-018).
  // Authored alongside rationale_text at proposal-creation time; the full
  // rationale_text remains available via the "View full rationale" expand.
  // Convention: ~200 chars. Not enforced at the DB layer.
  rationale_summary           String?
  // Sprint 4 §A.1 — structured range capture (Sprint 3 review §3a). Both
  // nullable for migration; expected populated when captured. Display
  // layer renders a single value when size_low === size_high ("$75K") and
  // a range when size_low < size_high ("$4M-$7M"). Float type mirrors the
  // existing size_proposed for consistency with existing helpers; the
  // prompt's @db.Decimal(15, 2) is a Postgres-specific attribute that
  // doesn't apply to SQLite, and the dollars() formatter takes number.
  size_low                    Float?
  size_high                   Float?
  // Sprint 4 §A.2 — sub-type within a Product family (Sprint 3 review §3b).
  // Free-text for demo phase; Pilot phase may convert to enum or Product
  // variant relation. Examples: "service_van" (Vehicle/Fleet Loan) /
  // "manufacturing_facility" (Owner-Occupied CRE) / "seasonal_smoothing"
  // (Working Capital LOC).
  product_subtype             String?
  created_at                  DateTime                @default(now())
  // Sprint 2 Prompt 2 §B — Prisma's @updatedAt directive auto-updates this
  // column on every mutation. Used by computeSuggestedNextStep to break
  // ties when a Member has multiple active engaged Recommendations: the
  // most recently engaged is the one to surface. Demo doesn't exercise
  // multi-engagement (one engaged Rec per Member), but the logic is now
  // honest about what "most recently engaged" means.
  updated_at                  DateTime                @default(now()) @updatedAt

  // The active Signals this Recommendation responds to (Q-016). Implicit m-n
  // join table _RecommendationRespondsToSignal. Populated for the three
  // featured Recommendations in the seed: Jenny's LOC responds to her seasonal
  // cash flow blocker + cash flow smoothing goal; Northland's Fleet Loan
  // responds to capacity blocker + fleet expansion goal; Cygnus's CRE responds
  // to the two triggers + the customer growth goal.
  responds_to_signals         Signal[]                @relation("RecommendationRespondsToSignal")

  @@index([member_id])
}

// MemberSummarySnapshot — Persisted, immutable record of the rendered
// Member summary at the moment of a Conversation save. Backs the audit
// trail for what a banker would have seen at that point in time. Surfacing
// these in banker-facing UI is deferred to post-demo (Q-015).
//
// One snapshot per (member, conversation) save. Snapshots are never
// updated or deleted once written.
model MemberSummarySnapshot {
  id               String       @id @default(uuid())
  member_id        String
  member           Member       @relation(fields: [member_id], references: [id])
  conversation_id  String
  conversation     Conversation @relation(fields: [conversation_id], references: [id])
  summary_text     String
  template_version Int
  generated_at     DateTime     @default(now())

  @@unique([member_id, conversation_id])
  @@index([member_id])
  @@index([conversation_id])
}

// ============================================================
// Sprint 4 §A.5 — Macro entity.
//
// A Macro is a banker-authored or external-research-authored briefing on a
// market condition, regulatory shift, or sector pattern that is currently
// affecting a defined set of Member Types. Macros surface in three places:
//   1. Member profile context banner (when a Member's Member Type matches
//      a current Macro)
//   2. Insight Engine Macro context tab (Sprint 5 work)
//   3. Growth Conversations Ask phase prompts (Sprint 4 Prompt 4.2 work)
//
// Authorship is dual-mode: an internal Banker (via authored_by_banker_id)
// or an external label (e.g., "Federal Reserve Bank of Minneapolis
// research") via authored_by_external_label. The schema supports both.
//
// Array fields (affected_industry_families, affected_member_types,
// evidence_links, related_topics) are stored as Json arrays in SQLite —
// Prisma's String[] is Postgres-only. Each Json array is a list of string
// IDs (or URLs for evidence_links). The application layer handles
// serialization.
// ============================================================

model Macro {
  id                          String     @id @default(cuid())
  title                       String
  summary                     String
  authored_by_banker_id       String?
  authored_by_banker          Banker?    @relation(fields: [authored_by_banker_id], references: [id])
  authored_by_external_label  String?
  authored_at                 DateTime
  effective_period_start      DateTime
  effective_period_end        DateTime?  // Null means "still effective"
  // affected_industry_families: Json array of IndustryFamily.id strings.
  affected_industry_families  Json
  // affected_member_types: Json array of MemberType.id strings.
  affected_member_types       Json
  recommended_response        String
  // evidence_links: Json array of URL strings.
  evidence_links              Json
  // related_topics: Json array of Topic.id strings.
  related_topics              Json
  created_at                  DateTime   @default(now())
  updated_at                  DateTime   @updatedAt

  @@index([authored_by_banker_id])
}

// ============================================================
// Sprint 4 §A.6 — ArtifactParameterCapture entity (Sprint 3 review §3c).
//
// Structured parameter capture for Show-step Artifact rendering. Each row
// represents one parameter the banker (or auto-fill system) supplied to
// the Artifact's parameter_schema, plus the provenance of that value.
//
// Note on relation target: the prompt names ArtifactShareRecord as the
// linked entity. ArtifactShareRecord doesn't exist as a first-class
// entity in the demo schema — Sprint 1 chose to keep share-record data
// in GrowthStepExecution.captured_data jsonb to avoid a second
// persistence path. So ArtifactParameterCapture links to the Show-step
// GrowthStepExecution directly. If a future sprint promotes
// ArtifactShareRecord to a first-class table, the relation can be
// re-pointed; the schema shape and the provenance enum stay.
// ============================================================

model ArtifactParameterCapture {
  id                          String              @id @default(cuid())
  growth_step_execution_id    String
  growth_step_execution       GrowthStepExecution @relation(fields: [growth_step_execution_id], references: [id])
  parameter_name              String
  parameter_value             String
  parameter_provenance        ParameterProvenance
  captured_at                 DateTime            @default(now())
  captured_by_banker_id       String
  captured_by_banker          Banker              @relation(fields: [captured_by_banker_id], references: [id])

  @@index([growth_step_execution_id])
  @@index([captured_by_banker_id])
}

// Sprint 4 §A.6 — provenance enum. Value descriptions live in
// lib/enum-descriptions.ts → PARAMETER_PROVENANCE_DESCRIPTIONS so summary
// templates and UI labels render banker-facing prose, not bare tokens.
enum ParameterProvenance {
  member_profile
  captured_signal
  banker_assumption
  member_stated_in_followup
}

// Sprint 4.6 Block C — ComplianceScanEvent: telemetry capture for the
// submit-time keyword scan over [FL:BANKER-PROSE] fields. Per
// COMPLIANCE.md §7.4 and the Sprint 4.6 prompt §C.5, every scan event
// (whether the banker continues, edits, or cancels) is logged so Pilot
// can calibrate the keyword list against real banker behavior.
//
// This is the lightweight stand-in for the full immutable trace log
// (deferred per Path C-modified to Pilot — see ARCHITECTURE_V2.md §11
// and Q-039 in OPEN_QUESTIONS.md). Demo phase doesn't surface this
// telemetry anywhere; it accumulates for analytics use post-EVP.
model ComplianceScanEvent {
  id              String   @id @default(uuid())
  occurred_at     DateTime @default(now())
  banker_id       String
  banker          Banker   @relation(fields: [banker_id], references: [id])
  // The form field that fired the scan, e.g.
  // "Resolve.customer_response", "Resolve.closing_notes",
  // "Resolve.action_card_description". Free-form string so new
  // [FL:BANKER-PROSE] fields can be added without schema changes.
  field_name      String
  // JSON array of { term: string, group: string } objects. Stored as
  // Json (TEXT under SQLite) so the structured shape survives without
  // a join table — query patterns are aggregations over (term × group)
  // counts, which Json operators handle adequately for demo scale.
  matched_terms   Json
  // Banker's response to the soft-advisory prompt:
  //   "continued"  — banker confirmed and saved
  //   "edited"     — banker returned to the field and revised
  //   "cancelled"  — banker discarded the capture
  banker_action   String
  // Optional Member context — populated when the scan fires inside a
  // member-context form (Resolve, ActionCard description). Not all
  // [FL:BANKER-PROSE] fields are member-context (e.g., a future
  // global note); nullable accommodates both shapes.
  member_id       String?
  member          Member?  @relation(fields: [member_id], references: [id])

  @@index([banker_id, occurred_at])
  @@index([field_name])
}

// ============================================================
// Sprint 4.7 Block B — v2 phase 1 entities (per ARCHITECTURE_V2 §11).
//
// Three new entities support the v2 workstation's two-layer model
// (objectives × activities). Existing entities (Member, Conversation,
// Banker, Artifact, Signal, SizingMeasurement, Recommendation,
// ActionCard) are reused unchanged; v2 reads work alongside v1.
//
// The `Objective` entity from ARCHITECTURE_V2 §11.1 is implemented as
// derived state in `lib/v2-objectives.ts` rather than a persisted
// table — objectives are largely computed from existing captures via
// the EVIDENCE_FRAMEWORK.md catalog. Persisting them would duplicate
// derivable state. Demo simplicity > schema purity.
//
// Migration `<timestamp>_sprint4_7_v2_phase_1_entities` ships the three
// CREATE TABLE statements + indexes additively. v1 schema unchanged.
// ============================================================

// Model — Sprint 4.7 Block B / ARCHITECTURE_V2 §11.2.
//
// Captures the + Model activity output. A Model is a banker-constructed
// artifact (cashflow projection, ROI calculation, etc.) with structured
// parameters, assumptions, and an output summary. The `built_with_member`
// boolean is the critical evidentiary distinction per ARCHITECTURE_V2
// §4: "With Member" (collaborative during conversation) is stronger
// evidence than "Banker draft."
//
// Supersession discipline parallel to Signal / SizingMeasurement: when
// a banker re-runs the model with refined assumptions, the new row
// references the prior via `superseded_by_id` and the prior is marked
// inactive. Audit trail preserved.
model Model {
  id                  String        @id @default(uuid())
  member_id           String
  member              Member        @relation(fields: [member_id], references: [id])
  conversation_id     String?
  conversation        Conversation? @relation(fields: [conversation_id], references: [id])
  // Optional reference to an Artifact this Model produced or
  // referenced. A Model may exist without an Artifact (e.g., a
  // banker-built calculation that wasn't formalized into a shareable
  // chart) and an Artifact may exist without a Model (the canonical
  // demo Artifacts pre-date v2's Model entity).
  artifact_id         String?
  artifact            Artifact?     @relation(fields: [artifact_id], references: [id])
  built_with_member   Boolean
  parameters          Json
  assumptions         Json
  output_summary      String
  built_at            DateTime      @default(now())
  built_by_banker_id  String
  built_by_banker     Banker        @relation(fields: [built_by_banker_id], references: [id])
  active              Boolean       @default(true)
  superseded_by_id    String?
  superseded_by       Model?        @relation("ModelSupersession", fields: [superseded_by_id], references: [id])
  superseded_at       DateTime?
  superseding_models  Model[]       @relation("ModelSupersession")

  show_events         ShowEvent[]

  // Sprint 5d Block A — parameterized artifact template support.
  // When set, the Model was built using an ArtifactTemplate;
  // template_parameters is a JSON-encoded object of parameter values
  // per the template's parameter_schema. Output summary, structural
  // content, and rendering all derive from template + parameters.
  template_id         String?
  template            ArtifactTemplate? @relation(fields: [template_id], references: [id])
  template_parameters String?

  @@index([member_id, active])
  @@index([conversation_id])
  @@index([artifact_id])
  @@index([template_id])
}

// ArtifactTemplate — Sprint 5d Block A.
//
// Parameterized artifact templates per Track. Each template defines
// the parameter_schema banker fills during + Model capture, the
// output_summary_template that renders with parameters, and structural
// content (chart spec / ROI table / SBA 504 roadmap) for artifact view.
// JSON fields are stored as String (SQLite convention; lib/factor-evaluator
// pattern reuse).
model ArtifactTemplate {
  id                          String        @id // ARTIFACT-TEMPLATE-NNN
  track_id                    String
  track                       TrackTemplate @relation(fields: [track_id], references: [id])

  title                       String
  description                 String

  // JSON-encoded array of Member-Type ids, or the literal 'broad'.
  member_type_applicability   String

  // JSON-encoded parameter schema:
  // { parameters: [{ key, label, type, options?, required?, default?, helper?, computed?, computation? }, ...] }
  parameter_schema            String
  // Template string with {parameter_key} placeholders. Rendered by
  // resolveTemplateString() in lib/artifact-template.ts.
  output_summary_template     String
  // JSON-encoded structural content. Shape varies by template type
  // (cashflow projection / ROI table / SBA 504 roadmap with stages).
  // Renderer dispatches on structural_content.type.
  structural_content          String

  created_at                  DateTime      @default(now())

  models                      Model[]

  @@index([track_id])
}

// Reaction — Sprint 4.7 Block B / ARCHITECTURE_V2 §11.3.
//
// Captures the + Reaction activity output: the Member's response to a
// Show event. The optional `member_quote` field is the evidentiary
// centerpiece — verbatim what the Member said. Subject to the Sprint
// 4.6 compliance keyword scan ([FL:BANKER-PROSE]).
//
// `show_event_id` is optional: a Reaction can be captured without a
// preceding Show (e.g., banker captures Member's reaction to a
// previously-known artifact). When present, it's the linkage that lets
// the captured feed render "Member reacted to <Show>."
model Reaction {
  id                    String        @id @default(uuid())
  member_id             String
  member                Member        @relation(fields: [member_id], references: [id])
  conversation_id       String?
  conversation          Conversation? @relation(fields: [conversation_id], references: [id])
  show_event_id         String?
  show_event            ShowEvent?    @relation(fields: [show_event_id], references: [id])
  response_value        ReactionValue
  member_quote          String?
  // Sprint 4.7.2 Block A — primary concern column. Stored as String
  // because the contextual taxonomy uses two different enum sets
  // (open-thread context vs decline-reason context). The reused
  // RecommendationPrimaryConcern enum (Sprint 4.6 v1 Resolve) covers
  // both contexts; storing as String avoids tight Prisma single-enum
  // coupling. Application-layer validates which subset is allowed
  // per response_value (see app/v2/.../capture-forms/reaction-form.tsx).
  primary_concern       String?
  captured_at           DateTime      @default(now())
  captured_by_banker_id String
  captured_by_banker    Banker        @relation(fields: [captured_by_banker_id], references: [id])

  @@index([member_id])
  @@index([conversation_id])
  @@index([show_event_id])
}

// Sprint 4.7.2 Block A — ReactionValue expansion. v2 Reaction subsumes
// v1 Resolve's terminal states; enum grows from 5 → 7 values. Per
// ARCHITECTURE_V2.md §11.7: v2 ReactionValue is a deliberate subset of
// v1 RecommendationResponse — `funded` moves to Navigate via ActionCard
// outcome; `neutral` is subsumed by absence-of-Reaction; `leaning_no`
// folds into `skeptical` for v2.
enum ReactionValue {
  engaged
  leaning_yes
  skeptical
  confused
  dismissive
  committed
  declined
}

// ShowEvent — Sprint 4.7 Block B / ARCHITECTURE_V2 §11.4.
//
// Captures the + Show activity output: the moment an Artifact was
// rendered to a Member during a conversation. Decouples "an artifact
// was produced" (Model) from "an artifact was rendered" (ShowEvent).
//
// The same Model can be Shown multiple times (Q1 review, Q2 follow-up,
// etc.); each Show is a distinct ShowEvent. ShowEvent without a Model
// is fine (e.g., showing the demo Artifact that pre-dates v2's Model
// entity).
model ShowEvent {
  id                  String        @id @default(uuid())
  member_id           String
  member              Member        @relation(fields: [member_id], references: [id])
  conversation_id     String?
  conversation        Conversation? @relation(fields: [conversation_id], references: [id])
  artifact_id         String
  artifact            Artifact      @relation(fields: [artifact_id], references: [id])
  model_id            String?
  model               Model?        @relation(fields: [model_id], references: [id])
  shown_at            DateTime      @default(now())
  shown_by_banker_id  String
  shown_by_banker     Banker        @relation(fields: [shown_by_banker_id], references: [id])
  context_note        String?

  reactions           Reaction[]

  @@index([member_id])
  @@index([artifact_id])
  @@index([conversation_id])
}

// ============================================================
// Sprint 5a.1 — Business Factor Matrix infrastructure.
//
// Four entities that drive the Track-ranking switchboard and (in
// Sprint 5a.2) the popup-as-workflow surface. Sourced from
// BUSINESS_FACTOR_MATRIX_v1.md at repo root:
//   - BusinessFactor: 28 factors organized by category (Section 1)
//   - TrackTemplate: 5 Tracks (Section 2)
//   - MatrixEntry: ~80 factor-track relevance rows with strength,
//                  threshold rule, banker rationale (Section 3)
//   - FactorCapture: per-Member captured factor values, with
//                    optional source linkage to existing Signal /
//                    SizingMeasurement / Reaction records (Section 4)
//
// These entities are additive — no v1 or earlier-v2 entity changes.
// The matrix is read-only at runtime (seed-driven); FactorCapture
// is the only matrix-related entity that grows during banker
// workflow.
// ============================================================

model BusinessFactor {
  // FACTOR-NNN identifier per matrix file Section 1.
  id                  String   @id
  name                String
  // Banker-facing diagnostic question; surfaces on + Quantify form
  // when banker selects this factor.
  diagnostic_question String
  // numerical | boolean | qualitative_select | qualitative_multi
  capture_mode        String
  // snake_case key used in MatrixEntry.threshold_rule field references
  // (e.g., "seasonal_variance_pct >= 20" looks up the FactorCapture
  // whose factor.field_name = "seasonal_variance_pct").
  field_name          String   @unique
  unit                String?
  // cashflow | capacity | decision_process | industry_structural |
  // member_stated | banking_relationship
  category            String
  // JSON-encoded array of allowed values for qualitative_select factors.
  enum_values         String?
  notes               String?
  created_at          DateTime @default(now())

  matrix_entries      MatrixEntry[]
  factor_captures     FactorCapture[]

  @@index([category])
  @@index([field_name])
}

model TrackTemplate {
  // TRACK-NNN identifier per matrix file Section 2.
  id                              String   @id
  name                            String
  banker_description              String
  typical_size_band               String?
  // JSON: { discover: [...], measure: [...], consult: [...], navigate: [...] }
  // Each array carries factor IDs (FACTOR-NNN) or symbolic strings
  // (e.g., "model_produced", "model_shown", "reaction_captured").
  // Sprint 5a.2's popup-as-workflow logic resolves the symbolic refs.
  required_evidence_per_objective Json
  // Sprint 9 Patch E — JSON string[] of MemberType.id values for which
  // this Track is a natural fit. Drives the Track context dropdown's
  // applicability filter on /v2/members/[id]. The "compare to other
  // lending products" surface ignores this filter so the banker can
  // still reach inapplicable Tracks when warranted. Nullable for
  // backward compatibility; treated as "applicable to all Member-Types"
  // when null (e.g., legacy synthetic data).
  member_type_applicability       Json?
  notes                           String?
  created_at                      DateTime @default(now())

  matrix_entries                  MatrixEntry[]
  artifact_templates              ArtifactTemplate[]
}

model MatrixEntry {
  id                String   @id @default(cuid())
  factor_id         String
  factor            BusinessFactor @relation(fields: [factor_id], references: [id])
  track_id          String
  track             TrackTemplate  @relation(fields: [track_id], references: [id])
  // strong | moderate | negligible | negative
  strength          String
  // Threshold rule string, evaluated by lib/factor-evaluator.ts.
  // Null for presence-based or unconditional matrix entries.
  // Examples: "seasonal_variance_pct >= 20",
  //           "growth_obstacle_tag == cashflow_volatility",
  //           "decision_timeline IN [6_months, 12_months]"
  threshold_rule    String?
  // Banker-facing rationale; surfaces in popup CTAs and the
  // Tracks-supported panel rationale text.
  banker_rationale  String
  created_at        DateTime @default(now())

  // The unique constraint includes strength because some factor-track
  // pairs have entries at multiple tiers (e.g., FACTOR-001/TRACK-001
  // has both a strong entry at threshold ≥ 20% and a moderate entry
  // at the 10..20% range).
  @@unique([factor_id, track_id, strength, threshold_rule])
  @@index([factor_id])
  @@index([track_id])
  @@index([strength])
}

model FactorCapture {
  id                  String   @id @default(cuid())
  member_id           String
  member              Member   @relation(fields: [member_id], references: [id])
  factor_id           String
  factor              BusinessFactor @relation(fields: [factor_id], references: [id])
  // One of the three value columns is set per the factor's capture_mode.
  numerical_value     Float?
  boolean_value       Boolean?
  qualitative_value   String?
  unit                String?
  // Optional traceability to the underlying capture entity. Lets the
  // popup-as-workflow surface (Sprint 5a.2) show "this factor was
  // captured via this Goal/SizingMeasurement/Reaction."
  source_signal_id    String?
  source_sizing_id    String?
  source_reaction_id  String?
  captured_at         DateTime @default(now())
  banker_id           String
  // Sprint 8 Block A — capture-mode dichotomy.
  //   'member_confirmed' — captured in-conversation with the Member,
  //     verbatim or directly observed. Default.
  //   'banker_estimate'  — banker's working assumption, pending Member
  //     confirmation in a future conversation. Surfaces a visual flag
  //     (Sprint 8 Block H) wherever the captured value is displayed.
  // The two-mode UI surfaces only at artifact missing-parameter CTAs
  // (Sprint 8 Block E); standard + Quantify defaults to member_confirmed.
  capture_mode        String   @default("member_confirmed")

  @@index([member_id])
  @@index([factor_id])
  @@index([member_id, factor_id])
}

// ============================================================
// Sprint 5b.1 — Insight architecture + specialist handoff
// ============================================================
//
// Three new entities:
//   - InsightPattern: senior-authored canonical Patterns (institutional
//     knowledge for banker consultative reference). Status workflow
//     supports draft → approved → archived.
//   - Insight: banker-authored, two-state lifecycle (routine when LLM
//     match confidence ≥ 0.7; novel when below). Can address a Signal.
//   - SpecialistHandoff: Layer 3 CTA artifact. Created when banker
//     initiates handoff to a specialist (CRE / SBA / treasury / credit).
// ============================================================

model InsightPattern {
  // PATTERN-NNN identifier from INSIGHT_PATTERN_LIBRARY_v1.md.
  id                          String   @id
  // FK to TrackTemplate.id (TRACK-001 etc.).
  track_id                    String
  // Signal-tag this Pattern addresses (e.g. cashflow_volatility,
  // capacity_limit, real_estate). Used by Lightbulb-icon ranking and
  // by the matching pipeline to filter candidates.
  signal_tag_scope            String
  // 'reframe' (reinterprets a captured fact) or 'implication'
  // (develops a not-yet-articulated consequence).
  insight_type                String
  // 200-char canonical statement, Member-Type-agnostic.
  content                     String
  // JSON: array of 2-3 Rackham-style implication questions.
  implication_questions       String
  // JSON: array of Member-Type identifiers where Pattern was observed.
  // Metadata for library navigation; not used in matching.
  member_type_origins         String
  // 'broad' or JSON-encoded array of Member-Type ids. Senior-author
  // judgment for which Member Types this Pattern applies to.
  member_type_applicability   String
  // 'draft' | 'approved' | 'archived'. All demo seed Patterns ship as
  // 'approved'.
  status                      String
  authored_at                 DateTime @default(now())
  authored_by                 String   // banker id of senior lender
  approved_at                 DateTime?
  approved_by                 String?

  insights                    Insight[]

  @@index([track_id])
  @@index([signal_tag_scope])
  @@index([track_id, signal_tag_scope])
}

model Insight {
  id                  String   @id @default(cuid())
  member_id           String
  member              Member   @relation(fields: [member_id], references: [id])
  // FK to TrackTemplate.id — banker chose this Track context when
  // authoring. May differ from current Track if banker switches.
  track_id            String
  // Optional Signal reference — the Goal/Blocker/Indecision/Trigger
  // this Insight addresses. Null when the Insight is Track-level not
  // Signal-attached.
  addresses_signal_id String?
  // 'reframe' | 'implication'. Default depends on addressed Signal
  // type per Block E.1 (Goal/Blocker → reframe; Indecision/Trigger
  // → implication).
  insight_type        String
  // 200-char banker authorship.
  content             String
  // FK to InsightPattern.id. Null when no clean match (state='novel').
  matched_pattern_id  String?
  matched_pattern     InsightPattern? @relation(fields: [matched_pattern_id], references: [id])
  // Anthropic API match-confidence judgment, 0-1. Null on novel.
  match_confidence    Float?
  // Cached LLM feedback string (200 char). Populated on save; survives
  // even if the LLM API is later unreachable.
  llm_feedback        String?
  // 'routine' (matched ≥ 0.7) | 'novel' (no match or below threshold).
  state               String
  authored_at         DateTime @default(now())
  authored_by         String   // banker_id

  @@index([member_id])
  @@index([track_id])
  @@index([addresses_signal_id])
  @@index([state])
  @@index([matched_pattern_id])
}

model SpecialistHandoff {
  id                       String   @id @default(cuid())
  member_id                String
  member                   Member   @relation(fields: [member_id], references: [id])
  track_id                 String
  // 'CRE specialists' | 'SBA specialists' | 'treasury management' |
  // 'commercial credit underwriting'. Stored as String for forward
  // compatibility with Pilot department-tag expansion.
  department_tag           String
  // Optional 200-char free-text notes about specialist preference.
  specialist_preference    String?
  // 'initiated' | 'specialist_engaged' | 'closed'. Demo flows to
  // 'initiated' only; status transitions are Pilot work.
  status                   String   @default("initiated")
  initiated_at             DateTime @default(now())
  initiated_by             String   // banker_id

  @@index([member_id])
  @@index([track_id])
  @@index([status])
}

// ============================================================
// Sprint 5b.2 — MemberWorkflowState (portfolio query support)
// ============================================================
//
// Denormalized per-Member workflow state. Recomputed on capture writes
// via lib/workflow-state.ts → recomputeWorkflowState(). Drives portfolio
// surfaces (Track Performance, Member portfolio, Coverage, Stage-skip)
// without per-query re-aggregation across Signals/Insights/Reactions/etc.
//
// Demo scale (~3 fixtures, ~30-40 captures total) doesn't need this for
// performance — synchronous on-write recompute is fine. Pilot scale
// (~thousands of Members) will need async recompute via queue (see
// BUILD_LOG Architectural Note 10).

model MemberWorkflowState {
  id        String  @id @default(cuid())
  member_id String  @unique
  member    Member  @relation(fields: [member_id], references: [id])

  // Capture density (drives Track Performance tier filters).
  total_captures        Int @default(0)
  factor_captures_count Int @default(0)
  signals_count         Int @default(0)
  insights_count        Int @default(0)
  reactions_count       Int @default(0)

  // Workflow state signals (drive Coverage + Member portfolio surfaces).
  open_thread_count   Int @default(0)
  stale_capture_count Int @default(0)

  // Last touch across all capture entities — drives Member portfolio
  // default sort (oldest-first to surface neglected Members).
  last_touch_at DateTime?

  // Track context. current_track_id mirrors the top-ranked Track from
  // rankTracksForMember at recompute time; null when ranker returns
  // empty (Member below 2-evidence threshold).
  current_track_id                 String?
  pending_action_card_count        Int     @default(0)
  pending_specialist_handoff_count Int     @default(0)

  recomputed_at DateTime @default(now()) @updatedAt

  @@index([member_id])
  @@index([last_touch_at])
  @@index([current_track_id])
}
