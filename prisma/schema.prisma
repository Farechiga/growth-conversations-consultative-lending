// Sprint 4 §4.1d Block C — TimeHorizon enum for forward-looking trigger
// signals. Replaces `recency` semantically for Trigger Signals where the
// banker-facing question is "when will this event hit?" rather than "how
// recently did it become observable?". The prompt §C.1 spec uses the
// banker-facing display labels "imminent / 3-6 months / 6-12 months /
// 12-24 months / longer"; the enum values are identifier-safe forms of
// those labels. The display layer (AskSection) renders the friendly
// labels; the storage value is the identifier.
enum TimeHorizon {
  imminent
  three_to_six_months
  six_to_twelve_months
  twelve_to_twenty_four_months
  longer
}

