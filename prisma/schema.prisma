// Blaze Member Signals — demo-phase schema.
// Translated from docs/design/03_Data_Framework.docx.
//
// Conventions (per CLAUDE.md §5):
//   - Model names PascalCase (Prisma convention).
//   - Field names snake_case (matches Data Framework as authoritative source).
//   - The internal `step_shape` enum uses lowercase values; bankers never see it.
//
// SQLite-specific adaptations from the Data Framework's PostgreSQL-leaning spec:
//   - jsonb → Json (Prisma stores as TEXT under SQLite)
//   - array<T> → either an explicit join model or a Json column. Join models are used
//     where order matters or where we'll query the relation; Json is used where the
//     value is read-mostly display data.
//   - decimal(p,s) → Float (SQLite has no decimal type; demo precision is sufficient)
//   - timestamp / date → DateTime (SQLite stores as ISO-8601 text)
//   - Multi-value enums (e.g., Banker.roles) → Json (SQLite has no native arrays)
//
// =====================================================================
// Named relationships (Semantic Discipline Principle 2)
// =====================================================================
//
// Prisma's @relation names below are join-table identifiers, not semantic
// verb-phrases. The semantic names — required reading for any LLM-facing surface
// or summary template — are catalogued here per Data Framework §3 and the brief's
// AI-native ontology rules:
//
// Member fits MemberType                          (Member.member_type)
// Member owned_by Banker                          (Member.primary_banker)
// Member belongs_to IndustryFamily                (Member.industry_family)
// Member has_many Conversation                    (Member.conversations)
// Member has_many Signal                          (Member.signals)
// Member has_many ActionCard                      (Member.action_cards)
// Member has_many Recommendation                  (Member.recommendations)
// Member holds Product (via core_sync_state.products_held — denormalized)
//
// MemberType is_characterized_by_blockers Topic   (MemberType.characteristic_blockers)
// MemberType is_characterized_by_triggers Topic   (MemberType.characteristic_triggers)
// MemberType is_characterized_by_goals Topic      (MemberType.characteristic_goals)
// MemberType typically_uses Product               (MemberType.typical_products)
// MemberType has_default GrowthTrack              (MemberType.default_growth_tracks)
// MemberType belongs_to IndustryFamily            (MemberType.industry_family)
//
// Conversation held_with Member                   (Conversation.member)
// Conversation led_by Banker                      (Conversation.banker)
// Conversation has_many GrowthStepExecution       (Conversation.growth_step_executions)
// Conversation produced_many Signal               (Conversation.signals)
// Conversation originated_action_cards ActionCard (Conversation.origin_action_cards)
//
// GrowthStepExecution executed_in Conversation    (GrowthStepExecution.conversation)
// GrowthStepExecution instance_of GrowthStep      (GrowthStepExecution.growth_step)
// GrowthStepExecution produced_signals Signal     (GrowthStepExecution.produced_signals)
// GrowthStepExecution produced_cards ActionCard   (GrowthStepExecution.produced_action_cards)
// GrowthStepExecution produced_recommendation Recommendation
//
// Signal belongs_to Conversation                  (Signal.conversation)
// Signal anchored_to Member                       (Signal.member)
// Signal references Topic                         (Signal.topic)
// Signal produced_by GrowthStepExecution          (Signal.growth_step_execution)
//
// ActionCard owned_by Banker                      (ActionCard.owner)
// ActionCard anchored_to Member                   (ActionCard.member)
// ActionCard originated_from Conversation         (ActionCard.origin_conversation)
// ActionCard spawned_by GrowthStepExecution       (ActionCard.origin_growth_step_execution)
// ActionCard funded_with Product                  (ActionCard.funded_product)
//
// GrowthStep authored_by Banker                   (GrowthStep.author)
// GrowthStep promoted_by Banker                   (GrowthStep.promoted_by)
// GrowthStep shows Artifact                       (GrowthStep.artifact)
// GrowthStep targets MemberType                   (GrowthStep.target_member_types)
// GrowthStep surfaced_by_topic Topic              (GrowthStep.trigger_signals)
//
// GrowthTrack applies_to MemberType               (GrowthTrack.target_member_type)
// GrowthTrack authored_by Banker                  (GrowthTrack.author)
// GrowthTrack contains_in_order GrowthStep        (GrowthTrack.growth_step_sequence via GrowthTrackStep)
// GrowthTrack triggered_by_blockers Topic         (GrowthTrack.target_blocker_topics)
// GrowthTrack triggered_by_triggers Topic         (GrowthTrack.target_trigger_topics)
// GrowthTrack surfaced_by Rule                    (GrowthTrack.surfacing_rules)
//
// Artifact reviewed_by Banker                     (Artifact.reviewed_by)
//
// Rule outputs GrowthTrack                        (Rule.output_growth_tracks)
// Rule promoted_by Banker                         (Rule.promoted_by)
//
// Topic has_parent Topic                          (Topic.parent_topic)
//
// Recommendation belongs_to Member                (Recommendation.member)
// Recommendation produced_by GrowthStepExecution  (Recommendation.growth_step_execution)
// Recommendation references_product Product       (Recommendation.product)
// Recommendation paired_with Product              (Recommendation.paired_product)
// Recommendation surfaced_by_rule Rule            (Recommendation.rule_that_fired)
// Recommendation responds_to Signal               (Recommendation.responds_to_signals — Q-016)
//
// MemberSummarySnapshot snapshots Member          (MemberSummarySnapshot.member)
// MemberSummarySnapshot generated_at_save_of Conversation
//                                                 (MemberSummarySnapshot.conversation)
//
// The runtime registry — used by lib/summaries.ts and any future LLM-facing
// surface — lives in lib/relation-names.ts. Keep it in sync with this block
// (Two-File Rule). When a relation is added to the schema, both this comment
// block and the registry must reflect it in the same commit.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

// URL lives in prisma.config.ts (Prisma 7 convention, not schema.prisma).
datasource db {
  provider = "sqlite"
}

