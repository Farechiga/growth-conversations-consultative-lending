# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# SQLite (demo-phase database)
*.db
*.db-journal
*.db-wal
*.db-shm
/prisma/*.db*
# Sprint 6 — committed seed snapshot ships with the Vercel deployment.
# Refresh via `pnpm db:snapshot` before deploying.
!/prisma/seed.db

# Playwright verification screenshot output dumps. Regenerated locally
# whenever the verify/probe scripts run; not source-of-truth.
scripts/.*-out/

# Claude Code user-local settings
.claude/settings.local.json

# Microsoft Office lock files (Word/Excel temp files prefixed `~$`)
~$*
